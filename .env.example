# Copy this to .env and fill in values
# No paid API keys needed — everything runs locally!

# Wake word sensitivity (0.0 - 1.0, higher = more sensitive)
WAKE_WORD_THRESHOLD=0.5
WAKE_WORD=hey_jarvis

# STT — faster-whisper (local, runs on your NVIDIA GPU)
WHISPER_MODEL=base.en        # options: tiny.en, base.en, small.en, medium.en, large-v3
WHISPER_DEVICE=cuda          # cuda = NVIDIA GPU (fast), cpu = fallback
WHISPER_COMPUTE_TYPE=float16 # float16 for GPU, int8 for CPU

# Intent engine — Ollama (local LLM, no API key)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1        # must be pulled first: ollama pull llama3.1

# Alara behavior
SILENCE_TIMEOUT_MS=1500
DEBUG=false
