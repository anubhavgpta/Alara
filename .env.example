# ALARA v0.2.0 Environment Configuration

# Gemini API (free at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Execution settings
MAX_RETRIES=3
STEP_TIMEOUT_S=30

# Logging
DEBUG=false
LOG_FILE=alara.log

# Memory
DB_PATH=alara.db

# Voice (disabled in v0.2)
# DEEPGRAM_API_KEY=
# WHISPER_MODEL=base.en
